FLASK_DEBUG=true

# OpenAI (opcional): sin esto, la app funciona igual, sólo no muestra el
# resumen con IA en los resultados.
OPENAI_PROJECT_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ANALYSIS_MODEL=gpt-4o-mini

# agregar el addon de Postgres la genera sola; copiarla acá para desarrollo local.
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

DMARC_REPORTS_MAILBOX=reports@tudominio.com
DMARC_WEBHOOK_SECRET=

# SMTP para mandar las alertas (services/notifications.py) — puede ser la
# misma casilla de DMARC_REPORTS_MAILBOX si el proveedor permite SMTP saliente.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=